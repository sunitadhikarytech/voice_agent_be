# Copy to `.env` and fill in locally. NEVER commit real values.
# All keys are read via app/config.py; see docs/configuration.md for the full reference.
# Secrets move to a secret manager in VA-14.

# --- Core (VA-19) ---
ENVIRONMENT=local          # local | dev | prod  (dev/prod require JWT_SECRET_KEY below)
PORT=8080                  # Cloud Run injects $PORT at runtime
LOG_LEVEL=INFO             # CRITICAL | ERROR | WARNING | INFO | DEBUG
API_PREFIX=/api/v1

# --- Provider selection (VA-30). Set all four to `mock` to run offline, no keys. ---
STT_PROVIDER=deepgram
LLM_PROVIDER=gemini
TTS_PROVIDER=cartesia
REALTIME_PROVIDER=openai

# --- Deepgram STT (VA-31) ---
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# --- ElevenLabs (VA-33 alt STT; VA-44 alt TTS shares the key) ---
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL=scribe_v2_realtime
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
ELEVENLABS_VOICE_ID=

# --- Gemini LLM (VA-34/36) ---
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_ENABLE_PROMPT_CACHING=true

# --- Cartesia TTS (VA-43) ---
CARTESIA_API_KEY=
CARTESIA_MODEL=sonic-2
CARTESIA_VOICE_ID=

# --- OpenAI Realtime (VA-46) — must be a beta-protocol model ---
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_VOICE=alloy

# --- Grounding (VA-35) & memory (VA-41) ---
SOURCE_DOC_PATH=              # path to .txt/.md/.pdf; empty = grounding off
CONTEXT_WINDOW_TOKENS=1000000
CONVERSATION_MEMORY_TOKENS=2000

# --- Auth (VA-15). Required in dev/prod. Setting it ENABLES bearer-JWT auth on
# /api/v1/*: requests need "Authorization: Bearer <HS256 jwt>" carrying sub+tenant+exp.
# Must be >= 32 bytes (openssl rand -hex 32). Empty (local) = API open, "default" tenant.
JWT_SECRET_KEY=

# --- CORS (VA-16). Comma-separated known origins; empty = no cross-origin access. ---
# The /ui dashboard is served same-origin and needs no entry. Wildcards are rejected.
ALLOWED_ORIGINS=           # e.g. https://app.example.com,https://staging.example.com

# --- Rate limiting (VA-17). Token bucket per API key (JWT sub) or client IP. ---
RATE_LIMIT_PER_MINUTE=0    # 0 = off (local default); e.g. 120 in deployments
RATE_LIMIT_BURST=0         # bucket capacity; 0 = same as the per-minute rate
