# Copy to `.env` and fill in locally. NEVER commit real values.
# All keys are read via app/config.py; secrets move to a secret manager in VA-14.

# --- Core (VA-19) ---
ENVIRONMENT=local          # local | dev | prod  (dev/prod require the secrets below)
PORT=8080                  # Cloud Run injects $PORT at runtime
LOG_LEVEL=INFO             # CRITICAL | ERROR | WARNING | INFO | DEBUG
API_PREFIX=/api/v1

# --- Provider keys (added/used by later tickets; leave blank) ---
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# --- Auth (VA-15) ---
JWT_SECRET_KEY=

# --- Grounding (VA-35) ---
SOURCE_DOC_PATH=

# --- CORS (VA-16), comma-separated ---
ALLOWED_ORIGINS=
